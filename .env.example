# Optional. The app builds without credentials; missing keyed sources are marked as explicit sample fallback.
# OpenDART disclosure list API key. Keep this server-side only.
# Vercel should set DART_API_KEY. OPENDART_API_KEY remains supported as a fallback.
DART_API_KEY=
OPENDART_API_KEY=

# Optional RSS URL for a future server-side ingestion job.
EQR_RSS_FEED_URL=

# Optional GDELT query override for future server-side ingestion jobs.
EQR_GDELT_QUERY=Korea economy

# Optional. Enables live Korea macro baselines for base rate, KTB 3Y, and M2 via Bank of Korea ECOS.
# Without this key, USD/KRW still uses the no-key Frankfurter daily FX API, while ECOS-only indicators show explicit sample fallback.
BOK_ECOS_API_KEY=
ECOS_API_KEY=

# Optional ECOS code overrides if the default table/item mapping needs adjustment.
EQR_ECOS_BASE_RATE_STAT_CODE=722Y001
EQR_ECOS_BASE_RATE_ITEM_CODE=0101000
EQR_ECOS_TREASURY_3Y_STAT_CODE=817Y002
EQR_ECOS_TREASURY_3Y_ITEM_CODE=010200000
EQR_ECOS_M2_STAT_CODE=161Y006
EQR_ECOS_M2_ITEM_CODE=BBHA00

DATABASE_URL=

CRON_SECRET=
