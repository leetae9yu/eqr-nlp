# Optional. The default demo uses fixtures and does not require credentials.
# OpenDART disclosure list API key. Keep this server-side only.
# Vercel should set DART_API_KEY. OPENDART_API_KEY remains supported as a fallback.
DART_API_KEY=
OPENDART_API_KEY=

# Optional RSS URL for a future server-side ingestion job.
EQR_RSS_FEED_URL=

# Optional GDELT query override for future server-side ingestion jobs.
EQR_GDELT_QUERY=Korea economy
